{
  "action_manifest_version": 1,
  "app_key": "com.local.vrec",
  "bindings": {
    "/actions/vrec": {
      "sources": [
        {
          "path": "/user/hand/left/input/trigger",
          "mode": "button",
          "inputs": {
            "click": {
              "output": "/actions/vrec/in/click"
            }
          }
        },
        {
          "path": "/user/hand/right/input/trigger",
          "mode": "button",
          "inputs": {
            "click": {
              "output": "/actions/vrec/in/click"
            }
          }
        },
        {
          "path": "/user/hand/left/input/grip",
          "mode": "button",
          "inputs": {
            "click": {
              "output": "/actions/vrec/in/grip"
            }
          }
        },
        {
          "path": "/user/hand/right/input/grip",
          "mode": "button",
          "inputs": {
            "click": {
              "output": "/actions/vrec/in/grip"
            }
          }
        },
        {
          "path": "/user/hand/left/input/thumbstick",
          "mode": "joystick",
          "inputs": {
            "position": {
              "output": "/actions/vrec/in/scale_axis"
            }
          }
        },
        {
          "path": "/user/hand/right/input/thumbstick",
          "mode": "joystick",
          "inputs": {
            "position": {
              "output": "/actions/vrec/in/scale_axis"
            }
          }
        }
      ],
      "poses": [
        {
          "output": "/actions/vrec/in/pointer_pose",
          "path": "/user/hand/left/pose/tip"
        },
        {
          "output": "/actions/vrec/in/pointer_pose",
          "path": "/user/hand/right/pose/tip"
        }
      ],
      "haptics": [
        {
          "output": "/actions/vrec/out/haptic",
          "path": "/user/hand/left/output/haptic"
        },
        {
          "output": "/actions/vrec/out/haptic",
          "path": "/user/hand/right/output/haptic"
        }
      ]
    }
  },
  "controller_type": "knuckles",
  "description": "VRec overlay bindings",
  "name": "VRec Index Controller"
}
